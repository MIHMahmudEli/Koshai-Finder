<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1B5E35"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/back_arrow"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/back_desc" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/meat_shop_label"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center" />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:contentDescription="@string/app_name" />
    </LinearLayout>

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <EditText
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/input_bg"
            android:hint="@string/search_hint_dots"
            android:textSize="14sp"
            android:paddingHorizontal="14dp"
            android:textColorHint="#BBBBBB"
            android:inputType="text"
            android:importantForAutofill="no" />
    </LinearLayout>

    <!-- Category Tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#FFFFFF"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="@string/categorie_tab"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="@string/mutton_label"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#1B5E35"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="@string/ribs_label"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="@string/keema_label"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingHorizontal="14dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Categories Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/meat_categories_label"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all_7"
                    android:textSize="12sp"
                    android:textColor="#1B5E35" />
            </LinearLayout>

            <!-- Category Images Row -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:layout_width="70dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                        <FrameLayout android:layout_width="60dp" android:layout_height="60dp" android:background="#FFF3E0">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🥩" android:textSize="28sp" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/beef_label" android:textSize="11sp" android:textColor="#1A1A1A" android:gravity="center" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="70dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                        <FrameLayout android:layout_width="60dp" android:layout_height="60dp" android:background="#F3E5F5">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🍖" android:textSize="28sp" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/mutton_label" android:textSize="11sp" android:textColor="#1A1A1A" android:gravity="center" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="70dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                        <FrameLayout android:layout_width="60dp" android:layout_height="60dp" android:background="#FCE4EC">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🍗" android:textSize="28sp" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/ribs_label" android:textSize="11sp" android:textColor="#1A1A1A" android:gravity="center" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="70dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                        <FrameLayout android:layout_width="60dp" android:layout_height="60dp" android:background="#E8F5E9">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🥓" android:textSize="28sp" />
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/keema_label" android:textSize="11sp" android:textColor="#1A1A1A" android:gravity="center" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Shop With Us Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/shop_with_us_upper"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all_arrow"
                    android:textSize="12sp"
                    android:textColor="#1B5E35" />
            </LinearLayout>

            <!-- Product Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true">

                <!-- Beef Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="110dp"
                            android:background="#FFF3E0">

                            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🥩" android:textSize="44sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:layout_margin="6dp"
                                android:text="♡"
                                android:textSize="18sp"
                                android:textColor="#CC0000" />
                        </FrameLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/beef_per_kg" android:textSize="13sp" android:textStyle="bold" android:textColor="#1A1A1A" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/rating_4_5" android:textSize="11sp" android:textColor="#888888" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/beef_price_390" android:textSize="13sp" android:textStyle="bold" android:textColor="#1B5E35" android:layout_marginTop="2dp" />
                            <Button android:id="@+id/btnAddBeef" android:layout_width="match_parent" android:layout_height="32dp" android:text="@string/add_to_cart" android:textSize="11sp" android:backgroundTint="#1B5E35" android:textColor="#FFFFFF" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Mutton Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="110dp"
                            android:background="#F3E5F5">

                            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🍖" android:textSize="44sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:layout_margin="6dp"
                                android:text="♡"
                                android:textSize="18sp"
                                android:textColor="#CC0000" />
                        </FrameLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/premium_mutton_label" android:textSize="13sp" android:textStyle="bold" android:textColor="#1A1A1A" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/rating_4_5" android:textSize="11sp" android:textColor="#888888" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/mutton_price_750" android:textSize="13sp" android:textStyle="bold" android:textColor="#1B5E35" android:layout_marginTop="2dp" />
                            <Button android:id="@+id/btnAddMutton" android:layout_width="match_parent" android:layout_height="32dp" android:text="@string/add_to_cart" android:textSize="11sp" android:backgroundTint="#1B5E35" android:textColor="#FFFFFF" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Ribs Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
                        <FrameLayout android:layout_width="match_parent" android:layout_height="110dp" android:background="#FCE4EC">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🍗" android:textSize="44sp" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/ribs_label" android:textSize="13sp" android:textStyle="bold" android:textColor="#1A1A1A" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/rating_4_5" android:textSize="11sp" android:textColor="#888888" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/ribs_price_350" android:textSize="13sp" android:textStyle="bold" android:textColor="#1B5E35" android:layout_marginTop="2dp" />
                            <Button android:id="@+id/btnAddRibs" android:layout_width="match_parent" android:layout_height="32dp" android:text="@string/add_to_cart" android:textSize="11sp" android:backgroundTint="#1B5E35" android:textColor="#FFFFFF" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Keema Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
                        <FrameLayout android:layout_width="match_parent" android:layout_height="110dp" android:background="#E8F5E9">
                            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🥣" android:textSize="44sp" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/keema_label" android:textSize="13sp" android:textStyle="bold" android:textColor="#1A1A1A" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/rating_4_5" android:textSize="11sp" android:textColor="#888888" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/keema_price_280" android:textSize="13sp" android:textStyle="bold" android:textColor="#1B5E35" android:layout_marginTop="2dp" />
                            <Button android:id="@+id/btnAddKeema" android:layout_width="match_parent" android:layout_height="32dp" android:text="@string/add_to_cart" android:textSize="11sp" android:backgroundTint="#1B5E35" android:textColor="#FFFFFF" android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>

            <!-- Weight Selector -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/weight_label"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:gravity="center" android:text="@string/weight_1kg" android:textSize="12sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="#1B5E35" android:layout_marginEnd="6dp" />
                <TextView android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:gravity="center" android:text="@string/weight_2kg" android:textSize="12sp" android:textColor="#555555" android:background="#E0E0E0" android:layout_marginEnd="6dp" />
                <TextView android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:gravity="center" android:text="@string/weight_3kg" android:textSize="12sp" android:textColor="#555555" android:background="#E0E0E0" android:layout_marginEnd="6dp" />
                <TextView android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:gravity="center" android:text="@string/weight_4kg" android:textSize="12sp" android:textColor="#555555" android:background="#E0E0E0" android:layout_marginEnd="6dp" />
                <TextView android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:gravity="center" android:text="@string/weight_5kg" android:textSize="12sp" android:textColor="#555555" android:background="#E0E0E0" />
            </LinearLayout>

            <Button
                android:id="@+id/btnAddToCart"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/add_to_cart_upper"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#1B5E35"
                android:textColor="#FFFFFF"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>