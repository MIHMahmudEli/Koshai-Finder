<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <View
            android:id="@+id/ivSkeletonPhoto"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="#E0E0E0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/tvSkeletonName"
            android:layout_width="140dp"
            android:layout_height="20dp"
            android:layout_marginStart="16dp"
            android:background="#E0E0E0"
            app:layout_constraintStart_toEndOf="@id/ivSkeletonPhoto"
            app:layout_constraintTop_toTopOf="@id/ivSkeletonPhoto" />

        <View
            android:id="@+id/tvSkeletonLocation"
            android:layout_width="100dp"
            android:layout_height="14dp"
            android:layout_marginTop="8dp"
            android:background="#EEEEEE"
            app:layout_constraintStart_toStartOf="@id/tvSkeletonName"
            app:layout_constraintTop_toBottomOf="@id/tvSkeletonName" />

        <View
            android:id="@+id/tvSkeletonRating"
            android:layout_width="60dp"
            android:layout_height="14dp"
            android:layout_marginTop="8dp"
            android:background="#EEEEEE"
            app:layout_constraintStart_toStartOf="@id/tvSkeletonName"
            app:layout_constraintTop_toBottomOf="@id/tvSkeletonLocation" />

        <View
            android:id="@+id/vSkeletonPrice"
            android:layout_width="70dp"
            android:layout_height="24dp"
            android:background="#E0E0E0"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivSkeletonPhoto" />

        <View
            android:id="@+id/btnSkeletonView"
            android:layout_width="100dp"
            android:layout_height="36dp"
            android:layout_marginTop="20dp"
            android:background="#E0E0E0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSkeletonRating" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
