<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5EFE6">

    <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_vintage_header"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:background="#20FFFFFF"
        app:icon="@android:drawable/ic_menu_revert"
        app:iconTint="#EAE3D2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/availability_settings_title"
        android:textColor="#FDFBF7"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="14dp"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_premium_card"
                android:orientation="vertical"
                android:padding="22dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/current_work_status_label"
                    android:textColor="#292524"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/statusToggleGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOnline"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/status_online"
                        android:textColor="#D4AF37"
                        app:strokeColor="#D4AF37" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBusy"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/status_busy"
                        android:textColor="#78716C"
                        app:strokeColor="#78716C" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOffline"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/status_offline"
                        android:textColor="#78716C"
                        app:strokeColor="#78716C" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="4dp"
                android:text="@string/eid_special_label"
                android:textColor="#78350F"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_premium_card"
                android:orientation="vertical"
                android:padding="22dp"
                android:elevation="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/iconMoon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/btn_star_big_off"
                        android:layout_centerVertical="true"
                        app:tint="#1E3A8A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/iconMoon"
                        android:layout_marginStart="12dp"
                        android:text="@string/enable_eid_mode"
                        android:textColor="#292524"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"/>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchEidMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/eid_mode_desc"
                    android:textColor="#57534E"
                    android:textSize="14sp"
                    android:lineSpacingExtra="3dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/surge_multiplier_label"
                    android:textColor="#292524"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderSurge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:valueFrom="1.0"
                    android:valueTo="3.0"
                    android:stepSize="0.1"
                    android:value="1.5"
                    app:thumbColor="#7F1D1D"
                    app:trackColorActive="#7F1D1D" />

                <TextView
                    android:id="@+id/tvSurgeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:text="@string/surge_value_default"
                    android:textColor="#7F1D1D"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="4dp"
                android:text="@string/preferred_hours_label"
                android:textColor="#78350F"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_premium_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="1dp">

                <CheckBox
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/working_hours_morning"
                    android:checked="true"
                    android:buttonTint="#064E3B"
                    android:textColor="#292524"
                    android:textSize="15sp"
                    android:paddingVertical="8dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E7E5E4"/>

                <CheckBox
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/working_hours_noon"
                    android:checked="true"
                    android:buttonTint="#064E3B"
                    android:textColor="#292524"
                    android:textSize="15sp"
                    android:paddingVertical="8dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E7E5E4"/>

                <CheckBox
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/working_hours_afternoon"
                    android:buttonTint="#064E3B"
                    android:textColor="#292524"
                    android:textSize="15sp"
                    android:paddingVertical="8dp"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveAvailability"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"
                android:text="Update Availability"
                android:textColor="#FDFBF7"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#7F1D1D"
                app:strokeColor="#F59E0B"
                app:strokeWidth="1.5dp"
                app:cornerRadius="14dp"
                app:elevation="4dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>