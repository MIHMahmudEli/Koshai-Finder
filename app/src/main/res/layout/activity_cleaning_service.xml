<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F8F9FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cleaning_service_title"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1B4332"
        android:layout_marginBottom="16dp"/>

    <CheckBox
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/slaughter_area_wash" />

    <CheckBox
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/waste_removal" />

    <Button
        android:id="@+id/btnOrderService"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="@string/get_cleaning_service"
        android:backgroundTint="#2D6A4F"
        android:layout_marginTop="24dp"/>

</LinearLayout>