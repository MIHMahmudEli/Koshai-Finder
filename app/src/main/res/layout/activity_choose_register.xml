<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Green Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1B5E35"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="@string/back_arrow"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginEnd="12dp"
            android:contentDescription="@string/back_desc" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_account_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <!-- Icon -->
        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="@string/user_icon_emoji"
            android:textSize="38sp"
            android:gravity="center"
            android:background="@drawable/circle_green_bg"
            android:layout_marginBottom="20dp"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/choose_account_type"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1B5E35"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/who_registering_as"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

        <!-- Customer Card Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/customerButton"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="@string/home_emoji"
                    android:textSize="26sp"
                    android:gravity="center"
                    android:background="@drawable/circle_green_light_bg"
                    android:layout_marginEnd="16dp"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/register_as_customer"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/customer_desc"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/right_arrow"
                    android:textSize="24sp"
                    android:textColor="#1B5E35"
                    android:importantForAccessibility="no" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Butcher Card Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/butcherButton"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="@string/knife_emoji"
                    android:textSize="26sp"
                    android:gravity="center"
                    android:background="@drawable/circle_yellow_bg"
                    android:layout_marginEnd="16dp"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/register_as_butcher"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/butcher_desc"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/right_arrow"
                    android:textSize="24sp"
                    android:textColor="#E8B530"
                    android:importantForAccessibility="no" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Already have account -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/already_have_account"
                android:textSize="13sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tvLoginLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_link"
                android:textSize="13sp"
                android:textColor="#1B5E35"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>