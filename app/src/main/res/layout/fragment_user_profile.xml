<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_luxury_gradient"> <ImageView
    android:id="@+id/btnHeaderBack"
    android:layout_width="28dp"
    android:layout_height="28dp"
    android:layout_marginStart="24dp"
    android:layout_marginTop="44dp"
    android:src="@android:drawable/abc_ic_ab_back_material"
    app:tint="#C5A880"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnHeaderEdit"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginEnd="24dp"
        android:src="@android:drawable/ic_menu_edit"
        app:tint="#C5A880"
        app:layout_constraintBottom_toBottomOf="@id/btnHeaderBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnHeaderBack" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/btnLogout"
        app:layout_constraintTop_toBottomOf="@id/btnHeaderBack">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <FrameLayout
                android:id="@+id/profileEmblemContainer"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivProfileShield"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvProfileUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="User Name"
                android:textColor="#EAD295"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/profileEmblemContainer" />

            <TextView
                android:id="@+id/tvProfileUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="user@example.com"
                android:textColor="#ECEFF1"
                android:textSize="15sp"
                android:alpha="0.85"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvProfileUserName" />

            <LinearLayout
                android:id="@+id/statBadgesLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvProfileUserEmail">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginHorizontal="8dp" android:src="@android:drawable/ic_dialog_info" app:tint="#C5A880" />
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginHorizontal="8dp" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#C5A880" />
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginHorizontal="8dp" android:src="@android:drawable/star_on" app:tint="#C5A880" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/infoGlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_profile_glass_card"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp"
                app:layout_constraintTop_toBottomOf="@id/statBadgesLayout">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="14dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_call"
                        app:tint="#EAD295" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="+880 1234 567890"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="medium" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#40FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="14dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="#EAD295" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Dhaka, Bangladesh"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="medium" />
                </LinearLayout>
            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/koshaiProfileGlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_profile_glass_card"
                android:paddingHorizontal="20dp"
                android:paddingVertical="20dp"
                app:layout_constraintTop_toBottomOf="@id/infoGlassCard">

                <ImageView
                    android:id="@+id/ivKoshaiCardIcon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="#EAD295"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvKoshaiCardTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="12dp"
                    android:text="Koshai Profile"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@id/ivKoshaiCardArrow"
                    app:layout_constraintStart_toEndOf="@id/ivKoshaiCardIcon"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Earn money by offering your skills"
                    android:textColor="#ECEFF1"
                    android:textSize="13sp"
                    android:alpha="0.8"
                    app:layout_constraintEnd_toEndOf="@id/tvKoshaiCardTitle"
                    app:layout_constraintStart_toStartOf="@id/tvKoshaiCardTitle"
                    app:layout_constraintTop_toBottomOf="@id/tvKoshaiCardTitle" />

                <ImageView
                    android:id="@+id/ivKoshaiCardArrow"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="#EAD295"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="36dp"
        android:background="@drawable/bg_luxury_logout_btn"
        android:text="Logout"
        android:textColor="#EAD295"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:letterSpacing="0.01"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>