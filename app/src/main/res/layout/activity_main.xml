<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Green Header Band -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#1B5E35"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginStart="-24dp"
            android:layout_marginEnd="-24dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <!-- Knife Icon placeholder -->
            <TextView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="#2E7D52"
                android:gravity="center"
                android:text="🔪"
                android:textSize="32sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KoshaiLagbe"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Complete Eid Solution"
                android:textSize="13sp"
                android:textColor="#A8D5B5"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card for Login Form -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E35"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Login to your account"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="24dp" />

                <!-- Email Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/emailEditText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_bg"
                    android:hint="Enter your email"
                    android:textColorHint="#BBBBBB"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="16dp" />

                <!-- Password Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/passwordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_bg"
                    android:hint="Enter your password"
                    android:textColorHint="#BBBBBB"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="10dp" />

                <!-- Forgot Password -->
                <TextView
                    android:id="@+id/forgotPasswordText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="Forgot Password?"
                    android:textColor="#1B5E35"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:layout_marginBottom="24dp" />

                <!-- Login Button -->
                <Button
                    android:id="@+id/loginButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="#1B5E35"
                    android:text="LOGIN"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Register Button -->
                <Button
                    android:id="@+id/registerButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="#E8B530"
                    android:text="CREATE ACCOUNT"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp" />

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  OR  "
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />
                </LinearLayout>

                <!-- Google Login Button -->
                <Button
                    android:id="@+id/googleLoginButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="Continue with Google"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/ic_google"
                    android:drawablePadding="10dp"
                    android:elevation="2dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bottom copyright -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:text="© 2024 KoshaiLagbe. All rights reserved."
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>