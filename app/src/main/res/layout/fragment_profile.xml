<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:background="#1B5E35"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PROFILE"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QURBANI\nSERVE"
            android:textColor="#E8B530"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomNav"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1B5E35"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="20dp"
                android:gravity="center_vertical">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:text="👤"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:background="#2E7D52" />

                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:text="✏️"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:background="#E8B530"
                        android:layout_gravity="bottom|end" />
                </FrameLayout>

                <!-- Name + Rating -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dipo Faaaa"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ 4.6 (Customer)"
                        android:textColor="#E8B530"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Edit Button -->
                <TextView
                    android:id="@+id/btnEdit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ Edit"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="#2E7D52"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Content padding -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ── ACCOUNT & PERSONAL INFO ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCOUNT &amp; PERSONAL INFO"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="16dp">

                    <!-- Personal Details -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardPersonalDetails"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#E8F5E9">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🪪" android:textSize="26sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PERSONAL\nDETAILS" android:textSize="10sp" android:textStyle="bold" android:textColor="#1B5E35" android:gravity="center" android:layout_marginTop="4dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Edit Details"
                                android:textSize="9sp"
                                android:textColor="#FFFFFF"
                                android:background="#1B5E35"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Address Book -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardAddressBook"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FDE8E8">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📍" android:textSize="26sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ADDRESS\nBOOK" android:textSize="10sp" android:textStyle="bold" android:textColor="#C0392B" android:gravity="center" android:layout_marginTop="4dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add New Address"
                                android:textSize="9sp"
                                android:textColor="#FFFFFF"
                                android:background="#C0392B"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Payment Methods -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardPaymentMethods"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFF8E1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💳" android:textSize="26sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PAYMENT\nMETHODS" android:textSize="10sp" android:textStyle="bold" android:textColor="#856404" android:gravity="center" android:layout_marginTop="4dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Manage Methods"
                                android:textSize="9sp"
                                android:textColor="#FFFFFF"
                                android:background="#856404"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- ── APP CONTROLS ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP CONTROLS"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="16dp">

                    <!-- My Bookings -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardMyBookings"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#E8F5E9">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📋" android:textSize="26sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MY\nBOOKINGS" android:textSize="10sp" android:textStyle="bold" android:textColor="#1B5E35" android:gravity="center" android:layout_marginTop="4dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="View Bookings"
                                android:textSize="9sp"
                                android:textColor="#FFFFFF"
                                android:background="#1B5E35"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Eid Tools Orders -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardEidToolsOrders"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFF8E1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔪" android:textSize="26sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EID TOOLS\nORDERS" android:textSize="10sp" android:textStyle="bold" android:textColor="#856404" android:gravity="center" android:layout_marginTop="4dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Track Orders"
                                android:textSize="9sp"
                                android:textColor="#FFFFFF"
                                android:background="#856404"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Service Preferences -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardServicePreferences"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#F5F5F5">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚙️" android:textSize="26sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SERVICE\nPREFERENCES" android:textSize="10sp" android:textStyle="bold" android:textColor="#555555" android:gravity="center" android:layout_marginTop="4dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Update Preferences"
                                android:textSize="9sp"
                                android:textColor="#FFFFFF"
                                android:background="#555555"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- ── SECURITY & SUPPORT ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SECURITY &amp; SUPPORT"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="16dp">

                    <!-- Change Password -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardChangePassword"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#E8F5E9">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔒" android:textSize="26sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHANGE\nPASSWORD" android:textSize="10sp" android:textStyle="bold" android:textColor="#1B5E35" android:gravity="center" android:layout_marginTop="4dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Update Password"
                                android:textSize="9sp"
                                android:textColor="#FFFFFF"
                                android:background="#1B5E35"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Notification Settings -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardNotificationSettings"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFF8E1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔔" android:textSize="26sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NOTIFICATION\nSETTINGS" android:textSize="10sp" android:textStyle="bold" android:textColor="#856404" android:gravity="center" android:layout_marginTop="4dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Configure Notifications"
                                android:textSize="9sp"
                                android:textColor="#FFFFFF"
                                android:background="#856404"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Support & Help -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardSupportHelp"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#F5F5F5">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎧" android:textSize="26sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SUPPORT\n&amp; HELP" android:textSize="10sp" android:textStyle="bold" android:textColor="#555555" android:gravity="center" android:layout_marginTop="4dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Contact Support"
                                android:textSize="9sp"
                                android:textColor="#FFFFFF"
                                android:background="#555555"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Switch to Koshai Mode -->
                <Button
                    android:id="@+id/btnSwitchKoshai"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="#1B5E35"
                    android:text="🟢  SWITCH TO KOSHAI MODE"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <!-- Log Out -->
                <Button
                    android:id="@+id/btnLogOut"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="#D32F2F"
                    android:text="↪  LOG OUT"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <!-- Delete Account -->
                <Button
                    android:id="@+id/btnDeleteAccount"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="🗑  DELETE ACCOUNT"
                    android:textColor="#D32F2F"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏠" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOME" android:textSize="9sp" android:textColor="#888888" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navBookings" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📋" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BOOKINGS" android:textSize="9sp" android:textColor="#888888" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navStore" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛒" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STORE" android:textSize="9sp" android:textColor="#888888" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navCharity" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🤝" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHARITY" android:textSize="9sp" android:textColor="#888888" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PROFILE" android:textSize="9sp" android:textColor="#1B5E35" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>