<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Dark Green Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1B5E35"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="@string/back_arrow"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginEnd="12dp"
            android:contentDescription="@string/back_desc_reg" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/butcher_registration_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Form Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Icon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:text="@string/knife_emoji"
                            android:textSize="32sp"
                            android:gravity="center"
                            android:background="@drawable/circle_yellow_bg"
                            android:importantForAccessibility="no" />
                    </LinearLayout>

                    <!-- Butcher Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/full_name_label"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/butcherName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_bg"
                        android:hint="@string/full_name_hint"
                        android:textColorHint="#BBBBBB"
                        android:textSize="14sp"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="14dp"
                        android:autofillHints="name" />

                    <!-- Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/email_label"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/butcherEmail"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_bg"
                        android:hint="@string/email_address_hint"
                        android:textColorHint="#BBBBBB"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="14dp"
                        android:autofillHints="emailAddress" />

                    <!-- Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/password_label"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/butcherPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_bg"
                        android:hint="@string/password_length_hint"
                        android:textColorHint="#BBBBBB"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="14dp"
                        android:autofillHints="password" />

                    <!-- Years of Experience -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/years_experience_label"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/butcherExperience"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_bg"
                        android:hint="@string/experience_hint"
                        android:textColorHint="#BBBBBB"
                        android:textSize="14sp"
                        android:inputType="number"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="14dp"
                        android:autofillHints="none" />

                    <!-- Location / District -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/location_label_reg"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/butcherLocation"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_bg"
                        android:hint="@string/location_hint_reg"
                        android:textColorHint="#BBBBBB"
                        android:textSize="14sp"
                        android:inputType="text"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="14dp"
                        android:autofillHints="postalAddress" />

                    <!-- Rate per Cow -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rate_cow_label"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/butcherRateCow"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_bg"
                        android:hint="@string/rate_cow_hint"
                        android:textColorHint="#BBBBBB"
                        android:textSize="14sp"
                        android:inputType="number"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="14dp"
                        android:autofillHints="none" />

                    <!-- Rate per Goat -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rate_goat_label"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/butcherRateGoat"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_bg"
                        android:hint="@string/rate_goat_hint"
                        android:textColorHint="#BBBBBB"
                        android:textSize="14sp"
                        android:inputType="number"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="24dp"
                        android:autofillHints="none" />

                    <!-- NID notice -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/notice_bg"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/info_emoji"
                            android:textSize="16sp"
                            android:layout_marginEnd="8dp"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nid_notice"
                            android:textSize="12sp"
                            android:textColor="#1B5E35" />
                    </LinearLayout>

                    <!-- Create Button -->
                    <Button
                        android:id="@+id/butcherCreateButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:backgroundTint="#E8B530"
                        android:text="@string/create_butcher_account_button"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Login link -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/already_registered"
                            android:textSize="13sp"
                            android:textColor="#888888" />

                        <TextView
                            android:id="@+id/tvLoginLink"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/login_here_link"
                            android:textSize="13sp"
                            android:textColor="#1B5E35"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>