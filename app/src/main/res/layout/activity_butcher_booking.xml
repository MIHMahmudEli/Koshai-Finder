<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1B5E35"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/back_arrow"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/back_desc" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/butcher_booking_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center" />

        <View
            android:layout_width="36dp"
            android:layout_height="36dp" />
    </LinearLayout>

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <EditText
            android:id="@+id/etSearchButcher"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/input_bg"
            android:hint="@string/search_butcher_hint"
            android:textSize="14sp"
            android:paddingHorizontal="14dp"
            android:textColorHint="#BBBBBB"
            android:inputType="text"
            android:importantForAutofill="no" />
    </LinearLayout>

    <!-- Tab Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#FFFFFF"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabNearby"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/filter_nearby"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1B5E35"
            android:background="#E8F5E9"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tabAvailable"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/filter_available"
            android:textSize="13sp"
            android:textColor="#888888"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tabNearbyBu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/filter_nearby_bu"
            android:textSize="13sp"
            android:textColor="#888888"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Map Placeholder -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="#D7E8D4">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/map_view_placeholder"
                    android:textSize="14sp"
                    android:textColor="#555555" />
            </FrameLayout>

            <!-- Top-Rated Butcher Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Profile Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:gravity="center"
                                android:text="@string/butcher_emoji"
                                android:textSize="28sp"
                                android:background="#E8F5E9"
                                android:contentDescription="@string/avatar_desc" />

                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:gravity="center"
                                android:text="@string/man_emoji"
                                android:textSize="28sp"
                                android:background="#FFF3E0"
                                android:layout_marginStart="4dp"
                                android:contentDescription="@string/avatar_desc" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/top_rated_label"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A1A" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/rating_text_placeholder"
                                android:textSize="12sp"
                                android:textColor="#888888" />
                        </LinearLayout>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnAddToOutlier"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text="@string/add_to_outlier"
                        android:textSize="12sp"
                        android:backgroundTint="#E8F5E9"
                        android:textColor="#1B5E35"
                        android:layout_marginBottom="12dp" />

                    <!-- Book Now Slot -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/book_now_slot"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="8dp" />

                    <!-- Day/Weight Slots Grid -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="5"
                        android:rowCount="2">

                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="@string/mon_1kg" android:textSize="10sp" android:background="#E8F5E9" android:textColor="#1B5E35" android:layout_margin="2dp" />
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="@string/tue_2kg" android:textSize="10sp" android:background="#1B5E35" android:textColor="#FFFFFF" android:layout_margin="2dp" />
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="@string/wed_2kg" android:textSize="10sp" android:background="#E8F5E9" android:textColor="#1B5E35" android:layout_margin="2dp" />
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="@string/thu_3kg" android:textSize="10sp" android:background="#E8F5E9" android:textColor="#1B5E35" android:layout_margin="2dp" />
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="@string/fri_5kg" android:textSize="10sp" android:background="#E8F5E9" android:textColor="#1B5E35" android:layout_margin="2dp" />
                        <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="@string/sun_3kg" android:textSize="10sp" android:background="#E8F5E9" android:textColor="#1B5E35" android:layout_margin="2dp" />
                    </GridLayout>

                    <Button
                        android:id="@+id/btnBookNow"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/book_now_upper"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1B5E35"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="14dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Second Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/top_rated_label"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/rating_4_0"
                            android:textSize="12sp"
                            android:textColor="#888888" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rating_details_placeholder"
                        android:textSize="11sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnBookNowSecondary"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="@string/book_now"
                            android:textSize="12sp"
                            android:backgroundTint="#1B5E35"
                            android:textColor="#FFFFFF" />

                        <Button
                            android:id="@+id/btnBookNowAlt"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="@string/book_now"
                            android:textSize="12sp"
                            android:backgroundTint="#E8B530"
                            android:textColor="#1A1A1A" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>