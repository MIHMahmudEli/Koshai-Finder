<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F8F9FA">

    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="@string/search_butcher_dots"
        android:padding="8dp"
        android:background="#FFFFFF"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:layout_marginBottom="16dp"
        android:importantForAutofill="no"
        android:autofillHints="none"
        android:inputType="text" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filter_available"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1B4332"
        android:layout_marginBottom="12dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@android:drawable/ic_menu_camera"
                android:contentDescription="@string/butcher_image_desc" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:text="@string/karim_team"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="@string/karim_specialty"
                    android:textSize="12sp"
                    android:textColor="#757575"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="@string/karim_price"
                    android:textStyle="bold"
                    android:textColor="#2D6A4F"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnBook"
                android:text="@string/book_label"
                android:textSize="12sp"
                android:backgroundTint="#2D6A4F"
                android:layout_width="wrap_content"
                android:layout_height="40dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>