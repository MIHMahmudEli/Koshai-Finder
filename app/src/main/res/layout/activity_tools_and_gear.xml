<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1B5E35"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tools &amp; Gear"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tab: Hardware | Knives -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tabHardware"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Hardware"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#1B5E35" />

        <TextView
            android:id="@+id/tabKnives"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Knives"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Product: Knives Kulves -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:text="🔪"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:background="#FFF8EC"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="Knives Kulves"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:text="⭐⭐⭐⭐" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        </LinearLayout>

                        <TextView
                            android:text="৳450 BDT"
                            android:textColor="#2E7D52"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBuyKnife"
                        android:text="BUY"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1B5E35"
                        android:layout_width="64dp"
                        android:layout_height="36dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Product: Chopping Blocks -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:text="🪵"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:background="#F0FFF4"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="Chopping Blocks"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:text="⭐⭐⭐⭐⭐" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        </LinearLayout>

                        <TextView
                            android:text="৳350 BDT"
                            android:textColor="#2E7D52"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBuyBlock"
                        android:text="BUY"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1B5E35"
                        android:layout_width="64dp"
                        android:layout_height="36dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Product: Chopping Blotes -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:text="🪓"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:background="#FDE8E8"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="Chopping Blotes"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:text="⭐⭐⭐⭐" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        </LinearLayout>

                        <TextView
                            android:text="৳280 BDT"
                            android:textColor="#2E7D52"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBuyBlote"
                        android:text="BUY"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1B5E35"
                        android:layout_width="64dp"
                        android:layout_height="36dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Product: Ropes -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:text="🪢"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:background="#FFF3CD"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="Ropes Ropes"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:text="⭐⭐⭐⭐⭐" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        </LinearLayout>

                        <TextView
                            android:text="৳150 BDT"
                            android:textColor="#2E7D52"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBuyRope"
                        android:text="BUY"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1B5E35"
                        android:layout_width="64dp"
                        android:layout_height="36dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- GET BUNDLE Button -->
            <Button
                android:id="@+id/btnGetBundle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="#1B5E35"
                android:text="GET BUNDLE"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>