<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1B5E35"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:baselineAligned="false">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="@string/back_arrow"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginEnd="12dp"
            android:contentDescription="@string/back_desc" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tools_and_gear_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tab: Hardware | Knives -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:elevation="2dp"
        android:baselineAligned="false">

        <TextView
            android:id="@+id/tabHardware"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/tab_hardware"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#1B5E35" />

        <TextView
            android:id="@+id/tabKnives"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/tab_knives"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Product: Knives Kulves -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:baselineAligned="false">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:text="🔪"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:background="#FFF8EC"
                        android:layout_marginEnd="14dp"
                        android:contentDescription="@string/product_knives_kulves" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="@string/product_knives_kulves"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false">
                            <TextView android:text="@string/rating_4_stars" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:contentDescription="@string/star_desc" />
                        </LinearLayout>

                        <TextView
                            android:text="@string/price_450_bdt"
                            android:textColor="#2E7D52"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBuyKnife"
                        android:text="@string/btn_buy"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1B5E35"
                        android:layout_width="64dp"
                        android:layout_height="36dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Product: Chopping Blocks -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:baselineAligned="false">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:text="🪵"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:background="#F0FFF4"
                        android:layout_marginEnd="14dp"
                        android:contentDescription="@string/product_chopping_blocks" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="@string/product_chopping_blocks"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false">
                            <TextView android:text="@string/rating_5_stars" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:contentDescription="@string/star_desc" />
                        </LinearLayout>

                        <TextView
                            android:text="@string/price_350_bdt"
                            android:textColor="#2E7D52"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBuyBlock"
                        android:text="@string/btn_buy"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1B5E35"
                        android:layout_width="64dp"
                        android:layout_height="36dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Product: Chopping Blotes -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:baselineAligned="false">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:text="🪓"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:background="#FDE8E8"
                        android:layout_marginEnd="14dp"
                        android:contentDescription="@string/product_chopping_blotes" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="@string/product_chopping_blotes"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false">
                            <TextView android:text="@string/rating_4_stars" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:contentDescription="@string/star_desc" />
                        </LinearLayout>

                        <TextView
                            android:text="@string/price_280_bdt"
                            android:textColor="#2E7D52"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBuyBlote"
                        android:text="@string/btn_buy"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1B5E35"
                        android:layout_width="64dp"
                        android:layout_height="36dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Product: Ropes -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:baselineAligned="false">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:text="🪢"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:background="#FFF3CD"
                        android:layout_marginEnd="14dp"
                        android:contentDescription="@string/product_ropes_ropes" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="@string/product_ropes_ropes"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false">
                            <TextView android:text="@string/rating_5_stars" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:contentDescription="@string/star_desc" />
                        </LinearLayout>

                        <TextView
                            android:text="@string/price_150_bdt"
                            android:textColor="#2E7D52"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnBuyRope"
                        android:text="@string/btn_buy"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1B5E35"
                        android:layout_width="64dp"
                        android:layout_height="36dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- GET BUNDLE Button -->
            <Button
                android:id="@+id/btnGetBundle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="#1B5E35"
                android:text="@string/btn_get_bundle"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>