<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_main_luxury_gradient">    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <com.example.koshailagbe.utils.DimOverlayView
            android:id="@+id/focusDimOverlay"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone"
            android:elevation="1dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Koshai Partner"
            android:textColor="#DFB664"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Find your perfect Koshai easily"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:alpha="0.8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <LinearLayout
            android:id="@+id/registrationCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_partner_glass_panel"
            android:orientation="vertical"
            android:padding="24dp"
            android:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:text="Personal Information"
            android:textColor="#0B3056" android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_partner_field_glass"
            android:hint="Full Name"
            android:textColorHint="#E2E8F0"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:inputType="textPersonName"
            android:drawableStart="@android:drawable/ic_menu_edit"
            android:drawablePadding="12dp"
            android:drawableTint="#94A3B8" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_partner_field_glass"
            android:hint="Email Address"
            android:textColorHint="#E2E8F0"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:inputType="textEmailAddress"
            android:drawableStart="@android:drawable/sym_action_email"
            android:drawablePadding="12dp"
            android:drawableTint="#94A3B8" />

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_partner_field_glass"
            android:hint="Phone Number"
            android:textColorHint="#E2E8F0"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:inputType="phone"
            android:drawableStart="@android:drawable/ic_menu_call"
            android:drawablePadding="12dp"
            android:drawableTint="#94A3B8" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etDistrict"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_partner_field_glass"
                android:hint="District"
                android:textColorHint="#E2E8F0"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:paddingHorizontal="16dp"
                android:inputType="text" />

            <EditText
                android:id="@+id/etUpazila"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_partner_field_glass"
                android:hint="Upazila"
                android:textColorHint="#E2E8F0"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:paddingHorizontal="16dp"
                android:inputType="text" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:text="Service Rates"
            android:textColor="#0B3056"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etRateCow"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_partner_field_glass"
            android:hint="Rate per Cow"
            android:textColorHint="#E2E8F0"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/etRateGoat"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_partner_field_glass"
            android:hint="Rate per Goat"
            android:textColorHint="#E2E8F0"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/etRateSheep"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_partner_field_glass"
            android:hint="Rate per Sheep"
            android:textColorHint="#E2E8F0"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:inputType="numberDecimal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:text="Account Security"
            android:textColor="#0B3056"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_partner_field_glass"
            android:hint="Password"
            android:textColorHint="#E2E8F0"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:drawableStart="@android:drawable/ic_lock_idle_lock"
            android:drawablePadding="12dp"
            android:drawableTint="#94A3B8" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRegisterKoshai"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_partner_submit_btn"
            android:text="Submit Application"
            android:textColor="#DFB664"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvBackToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:padding="8dp"
        android:text="Already have an account? Login"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:alpha="0.9" />

</LinearLayout>
</ScrollView>