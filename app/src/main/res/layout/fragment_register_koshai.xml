<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_onboarding_luxury"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="48dp"
        android:text="Koshai Partner"
        android:textColor="#E5C158" android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="3"
        android:shadowRadius="4" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="36dp"
        android:text="Find your perfect of Koshai easily"
        android:textColor="#D1D5DB"
        android:textSize="14sp"
        android:alpha="0.85" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_luxury_logo_glass" android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Personal Information"
                android:textColor="#E5C158"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilName"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="Full Name"
                android:textColorHint="#94A3B8"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintTextColor="#E5C158"
                app:startIconDrawable="@android:drawable/ic_menu_edit"
                app:startIconTint="#D1D5DB">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_luxury_input_box"
                    android:inputType="textPersonName"
                    android:textColor="#FFFFFF"
                    android:paddingVertical="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="Email Address"
                android:textColorHint="#94A3B8"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintTextColor="#E5C158"
                app:startIconDrawable="@android:drawable/sym_action_email"
                app:startIconTint="#D1D5DB">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_luxury_input_box"
                    android:inputType="textEmailAddress"
                    android:textColor="#FFFFFF"
                    android:paddingVertical="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPhone"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="Phone Number"
                android:textColorHint="#94A3B8"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintTextColor="#E5C158"
                app:prefixText="+88 "
                app:prefixTextColor="#FFFFFF"
                app:startIconDrawable="@android:drawable/ic_menu_call"
                app:startIconTint="#D1D5DB">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_luxury_input_box"
                    android:inputType="phone"
                    android:maxLength="11"
                    android:textColor="#FFFFFF"
                    android:paddingVertical="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDistrict"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:hint="District"
                    android:textColorHint="#94A3B8"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintTextColor="#E5C158">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDistrict"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_luxury_input_box"
                        android:inputType="text"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="14dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUpazila"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:hint="Upazila"
                    android:textColorHint="#94A3B8"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintTextColor="#E5C158">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUpazila"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_luxury_input_box"
                        android:inputType="text"
                        android:textColor="#FFFFFF"
                        android:paddingVertical="14dp"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:text="Service Rates"
                android:textColor="#E5C158"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRateCow"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Rate per Cow"
                android:textColorHint="#94A3B8"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintTextColor="#E5C158"
                app:suffixText="৳"
                app:suffixTextColor="#FFFFFF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRateCow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_luxury_input_box"
                    android:inputType="numberDecimal"
                    android:textColor="#FFFFFF"
                    android:paddingVertical="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRateGoat"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Rate per Goat"
                android:textColorHint="#94A3B8"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintTextColor="#E5C158"
                app:suffixText="৳"
                app:suffixTextColor="#FFFFFF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRateGoat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_luxury_input_box"
                    android:inputType="numberDecimal"
                    android:textColor="#FFFFFF"
                    android:paddingVertical="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRateSheep"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="Rate per Sheep"
                android:textColorHint="#94A3B8"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintTextColor="#E5C158"
                app:suffixText="৳"
                app:suffixTextColor="#FFFFFF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRateSheep"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_luxury_input_box"
                    android:inputType="numberDecimal"
                    android:textColor="#FFFFFF"
                    android:paddingVertical="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:text="Account Security"
                android:textColor="#E5C158"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:hint="Password"
                android:textColorHint="#94A3B8"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintTextColor="#E5C158"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="#D1D5DB"
                app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                app:startIconTint="#D1D5DB">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_luxury_input_box"
                    android:inputType="textPassword"
                    android:textColor="#FFFFFF"
                    android:paddingVertical="14dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegisterKoshai"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_btn_submit_luxury"
                android:text="Submit Application"
                android:textColor="#E5C158"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                app:backgroundTint="@android:color/transparent"
                app:elevation="4dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvBackToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="16dp"
        android:padding="8dp"
        android:text="Already have an account? Login"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:alpha="0.9" />

</LinearLayout>
</ScrollView>