<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- Splash -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.koshailagbe.fragment.SplashFragment">
        <action android:id="@+id/action_splashFragment_to_loginFragment"         app:destination="@id/loginFragment" />
        <action android:id="@+id/action_splashFragment_to_userHomeFragment"      app:destination="@id/userHomeFragment" />
        <action android:id="@+id/action_splashFragment_to_koshaiDashboardFragment"    app:destination="@id/koshaiDashboardFragment" />
        <action android:id="@+id/action_splashFragment_to_adminHomeFragment"     app:destination="@id/adminHomeFragment" />
        <action android:id="@+id/action_splashFragment_to_roleFragment"          app:destination="@id/roleFragment" />
    </fragment>

    <!-- Login -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.koshailagbe.fragment.LoginFragment"
        android:label="Login">
        <action android:id="@+id/action_loginFragment_to_roleFragment"                  app:destination="@id/roleFragment" />
        <action android:id="@+id/action_loginFragment_to_userHomeFragment"               app:destination="@id/userHomeFragment" />
        <action android:id="@+id/action_loginFragment_to_koshaiDashboardFragment"             app:destination="@id/koshaiDashboardFragment" />
        <action android:id="@+id/action_loginFragment_to_adminHomeFragment"              app:destination="@id/adminHomeFragment" />
        <action android:id="@+id/action_loginFragment_to_forgotPasswordFragment"         app:destination="@id/forgotPasswordFragment" />
        <action android:id="@+id/action_loginFragment_to_emailVerificationFragment"      app:destination="@id/emailVerificationFragment" />
    </fragment>

    <!-- Forgot Password -->
    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.example.koshailagbe.fragment.ForgotPasswordFragment"
        android:label="Forgot Password" />

    <!-- Role Select -->
    <fragment
        android:id="@+id/roleFragment"
        android:name="com.example.koshailagbe.fragment.RoleFragment"
        android:label="Choose Role">
        <action android:id="@+id/action_roleFragment_to_registerUserFragment"   app:destination="@id/registerUserFragment" />
        <action android:id="@+id/action_roleFragment_to_registerKoshaiFragment" app:destination="@id/registerKoshaiFragment" />
        <action android:id="@+id/action_roleFragment_to_userHomeFragment"       app:destination="@id/userHomeFragment" />
        <action android:id="@+id/action_roleFragment_to_koshaiDashboardFragment"     app:destination="@id/koshaiDashboardFragment" />
    </fragment>

    <!-- Register User -->
    <fragment
        android:id="@+id/registerUserFragment"
        android:name="com.example.koshailagbe.fragment.RegisterUserFragment"
        android:label="Register as User">
        <action android:id="@+id/action_registerUserFragment_to_userHomeFragment"           app:destination="@id/userHomeFragment" />
        <action android:id="@+id/action_registerUserFragment_to_emailVerificationFragment"  app:destination="@id/emailVerificationFragment" />
    </fragment>

    <!-- Register Koshai -->
    <fragment
        android:id="@+id/registerKoshaiFragment"
        android:name="com.example.koshailagbe.fragment.RegisterKoshaiFragment"
        android:label="Register as Koshai">
        <action android:id="@+id/action_registerKoshaiFragment_to_koshaiDashboardFragment"          app:destination="@id/koshaiDashboardFragment" />
        <action android:id="@+id/action_registerKoshaiFragment_to_emailVerificationFragment"   app:destination="@id/emailVerificationFragment" />
    </fragment>

    <!-- Email Verification -->
    <fragment
        android:id="@+id/emailVerificationFragment"
        android:name="com.example.koshailagbe.fragment.EmailVerificationFragment"
        android:label="Verify Email">
        <argument
            android:name="destination"
            app:argType="string"
            android:defaultValue="user" />
        <action android:id="@+id/action_emailVerificationFragment_to_userHomeFragment"   app:destination="@id/userHomeFragment" />
        <action android:id="@+id/action_emailVerificationFragment_to_koshaiDashboardFragment" app:destination="@id/koshaiDashboardFragment" />
        <action android:id="@+id/action_emailVerificationFragment_to_loginFragment"      app:destination="@id/loginFragment" />
    </fragment>

    <!-- OTP Fragment (legacy - kept for compatibility) -->
    <fragment
        android:id="@+id/otpFragment"
        android:name="com.example.koshailagbe.fragment.OtpFragment">
        <action android:id="@+id/action_otpFragment_to_roleFragment"         app:destination="@id/roleFragment" />
        <action android:id="@+id/action_otpFragment_to_userHomeFragment"     app:destination="@id/userHomeFragment" />
        <action android:id="@+id/action_otpFragment_to_koshaiDashboardFragment"   app:destination="@id/koshaiDashboardFragment" />
    </fragment>

    <!-- User Home -->
    <fragment
        android:id="@+id/userHomeFragment"
        android:name="com.example.koshailagbe.fragment.UserHomeFragment" />

    <!-- Koshai Screens -->
    <fragment
        android:id="@+id/koshaiDashboardFragment"
        android:name="com.example.koshailagbe.fragment.KoshaiDashboardFragment"
        android:label="Koshai Dashboard">
        <action android:id="@+id/action_koshaiDashboardFragment_to_bookingManagerFragment" app:destination="@id/bookingManagerFragment" />
        <action android:id="@+id/action_koshaiDashboardFragment_to_earningsFragment"       app:destination="@id/earningsFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookingManagerFragment"
        android:name="com.example.koshailagbe.fragment.BookingManagerFragment"
        android:label="Booking Manager">
        <action android:id="@+id/action_bookingManagerFragment_to_bookingDetailFragment" app:destination="@id/bookingDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/earningsFragment"
        android:name="com.example.koshailagbe.fragment.EarningsFragment"
        android:label="Earnings" />

    <!-- Admin Home -->
    <fragment
        android:id="@+id/adminHomeFragment"
        android:name="com.example.koshailagbe.fragment.AdminHomeFragment" />

</navigation>
