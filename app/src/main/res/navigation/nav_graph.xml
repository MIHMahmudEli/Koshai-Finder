<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- Splash -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.koshailagbe.fragment.SplashFragment">
        <action android:id="@+id/action_splashFragment_to_loginFragment"         app:destination="@id/loginFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_splashFragment_to_userHomeFragment"      app:destination="@id/userHomeFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_splashFragment_to_koshaiDashboardFragment"    app:destination="@id/koshaiDashboardFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_splashFragment_to_adminHomeFragment"     app:destination="@id/adminHomeFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_splashFragment_to_roleFragment"          app:destination="@id/roleFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Login -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.koshailagbe.fragment.LoginFragment"
        android:label="Login">
        <action android:id="@+id/action_loginFragment_to_roleFragment"                  app:destination="@id/roleFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_loginFragment_to_userHomeFragment"               app:destination="@id/userHomeFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_loginFragment_to_koshaiDashboardFragment"             app:destination="@id/koshaiDashboardFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_loginFragment_to_adminHomeFragment"              app:destination="@id/adminHomeFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_loginFragment_to_forgotPasswordFragment"         app:destination="@id/forgotPasswordFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_loginFragment_to_emailVerificationFragment"      app:destination="@id/emailVerificationFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Forgot Password -->
    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.example.koshailagbe.fragment.ForgotPasswordFragment"
        android:label="Forgot Password"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />

    <!-- Role Select -->
    <fragment
        android:id="@+id/roleFragment"
        android:name="com.example.koshailagbe.fragment.RoleFragment"
        android:label="Choose Role">
        <action android:id="@+id/action_roleFragment_to_registerUserFragment"   app:destination="@id/registerUserFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_roleFragment_to_registerKoshaiFragment" app:destination="@id/registerKoshaiFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_roleFragment_to_userHomeFragment"       app:destination="@id/userHomeFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_roleFragment_to_koshaiDashboardFragment"     app:destination="@id/koshaiDashboardFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Register User -->
    <fragment
        android:id="@+id/registerUserFragment"
        android:name="com.example.koshailagbe.fragment.RegisterUserFragment"
        android:label="Register as User">
        <action android:id="@+id/action_registerUserFragment_to_userHomeFragment"           app:destination="@id/userHomeFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_registerUserFragment_to_emailVerificationFragment"  app:destination="@id/emailVerificationFragment"        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Register Koshai -->
    <fragment
        android:id="@+id/registerKoshaiFragment"
        android:name="com.example.koshailagbe.fragment.RegisterKoshaiFragment"
        android:label="Register as Koshai">
        <action android:id="@+id/action_registerKoshaiFragment_to_koshaiDashboardFragment"          app:destination="@id/koshaiDashboardFragment" />
        <action android:id="@+id/action_registerKoshaiFragment_to_emailVerificationFragment"   app:destination="@id/emailVerificationFragment" />
    </fragment>

    <!-- Email Verification -->
    <fragment
        android:id="@+id/emailVerificationFragment"
        android:name="com.example.koshailagbe.fragment.EmailVerificationFragment"
        android:label="Verify Email">
        <argument
            android:name="destination"
            app:argType="string"
            android:defaultValue="user" />
        <action android:id="@+id/action_emailVerificationFragment_to_userHomeFragment"   app:destination="@id/userHomeFragment" />
        <action android:id="@+id/action_emailVerificationFragment_to_koshaiDashboardFragment" app:destination="@id/koshaiDashboardFragment" />
        <action android:id="@+id/action_emailVerificationFragment_to_loginFragment"      app:destination="@id/loginFragment" />
    </fragment>

    <!-- OTP Fragment (legacy - kept for compatibility) -->
    <fragment
        android:id="@+id/otpFragment"
        android:name="com.example.koshailagbe.fragment.OtpFragment">
        <action android:id="@+id/action_otpFragment_to_roleFragment"         app:destination="@id/roleFragment" />
        <action android:id="@+id/action_otpFragment_to_userHomeFragment"     app:destination="@id/userHomeFragment" />
        <action android:id="@+id/action_otpFragment_to_koshaiDashboardFragment"   app:destination="@id/koshaiDashboardFragment" />
    </fragment>

    <!-- User Home -->
    <fragment
        android:id="@+id/userHomeFragment"
        android:name="com.example.koshailagbe.fragment.UserHomeFragment"
        android:label="Koshai Finder">
        <action
            android:id="@+id/action_userHomeFragment_to_userKoshaiDetailFragment"
            app:destination="@id/userKoshaiDetailFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_userHomeFragment_to_userBookingsFragment"
            app:destination="@id/userBookingsFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_userHomeFragment_to_userProfileFragment"
            app:destination="@id/userProfileFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/userProfileFragment"
        android:name="com.example.koshailagbe.fragment.UserProfileFragment"
        android:label="My Profile">
        <action
            android:id="@+id/action_userProfileFragment_to_editProfileFragment"
            app:destination="@id/editProfileFragment"
            app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/userBookingsFragment"
        android:name="com.example.koshailagbe.fragment.UserBookingsFragment"
        android:label="My Bookings">
        <action
            android:id="@+id/action_userBookingsFragment_to_reviewFragment"
            app:destination="@id/reviewFragment" />
    </fragment>

    <fragment
        android:id="@+id/reviewFragment"
        android:name="com.example.koshailagbe.fragment.ReviewFragment"
        android:label="Rate Koshai">
        <argument
            android:name="bookingId"
            app:argType="string" />
        <argument
            android:name="koshaiId"
            app:argType="string" />
        <argument
            android:name="koshaiName"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/chatListFragment"
        android:name="com.example.koshailagbe.fragment.ChatListFragment"
        android:label="Inbox">
        <action
            android:id="@+id/action_chatListFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.example.koshailagbe.fragment.ChatFragment"
        android:label="Chat">
        <argument
            android:name="receiverId"
            app:argType="string" />
        <argument
            android:name="receiverName"
            android:defaultValue="@null"
            app:argType="string"
            app:nullable="true" />
        <argument
            android:name="receiverPhoto"
            android:defaultValue="@null"
            app:argType="string"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/userKoshaiDetailFragment"
        android:name="com.example.koshailagbe.fragment.UserKoshaiDetailFragment"
        android:label="Koshai Details">
        <argument
            android:name="koshaiId"
            app:argType="string" />
        <action
            android:id="@+id/action_userKoshaiDetailFragment_to_bookingRequestFragment"
            app:destination="@id/bookingRequestFragment" />
        <action
            android:id="@+id/action_userKoshaiDetailFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookingRequestFragment"
        android:name="com.example.koshailagbe.fragment.BookingRequestFragment"
        android:label="Booking Request" />

    <!-- Koshai Screens -->
    <fragment
        android:id="@+id/koshaiDashboardFragment"
        android:name="com.example.koshailagbe.fragment.KoshaiDashboardFragment"
        android:label="Koshai Dashboard">
        <action
            android:id="@+id/action_koshaiDashboardFragment_to_bookingManagerFragment"
            app:destination="@id/bookingManagerFragment" />
        <action
            android:id="@+id/action_koshaiDashboardFragment_to_earningsFragment"
            app:destination="@id/earningsFragment" />
        <action
            android:id="@+id/action_koshaiDashboardFragment_to_availabilityFragment"
            app:destination="@id/availabilityFragment" />
        <action
            android:id="@+id/action_koshaiDashboardFragment_to_leaderboardFragment"
            app:destination="@id/leaderboardFragment" />
        <action
            android:id="@+id/action_koshaiDashboardFragment_to_koshaiProfileFragment"
            app:destination="@id/koshaiProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/availabilityFragment"
        android:name="com.example.koshailagbe.fragment.AvailabilityFragment"
        android:label="Availability" />

    <fragment
        android:id="@+id/leaderboardFragment"
        android:name="com.example.koshailagbe.fragment.LeaderboardFragment"
        android:label="Leaderboard" />

    <fragment
        android:id="@+id/koshaiProfileFragment"
        android:name="com.example.koshailagbe.fragment.KoshaiProfileFragment"
        android:label="Profile">
        <action
            android:id="@+id/action_koshaiProfileFragment_to_editProfileFragment"
            app:destination="@id/editProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.example.koshailagbe.fragment.EditProfileFragment"
        android:label="Edit Profile" />

    <fragment
        android:id="@+id/bookingManagerFragment"
        android:name="com.example.koshailagbe.fragment.BookingManagerFragment"
        android:label="Booking Manager">
        <action android:id="@+id/action_bookingManagerFragment_to_bookingDetailFragment" app:destination="@id/bookingDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/earningsFragment"
        android:name="com.example.koshailagbe.fragment.EarningsFragment"
        android:label="Earnings" />

    <fragment
        android:id="@+id/bookingDetailFragment"
        android:name="com.example.koshailagbe.fragment.BookingDetailFragment"
        android:label="Booking Details">
        <action android:id="@+id/action_bookingDetailFragment_to_chatFragment" app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.example.koshailagbe.fragment.ChatFragment"
        android:label="Chat" />

    <!-- Admin Home -->
    <fragment
        android:id="@+id/adminHomeFragment"
        android:name="com.example.koshailagbe.fragment.AdminHomeFragment" />

</navigation>
